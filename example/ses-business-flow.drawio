<mxfile host="drawio-cmd">
  <diagram name="SES Business Flow" id="ses-flow-1">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="SES Business Flow" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="450" y="15" width="400" height="40" as="geometry"/>
        </mxCell>

        <!-- Swimlane: Sales / Account Manager -->
        <mxCell id="lane-sales" value="Sales / Account Manager" style="shape=swimlane;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;horizontal=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="1260" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="start" value="" style="ellipse;fillColor=#d5e8d4;strokeColor=#82b366;aspect=fixed;" vertex="1" parent="lane-sales">
          <mxGeometry x="20" y="55" width="40" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="client-need" value="Receive Client&#xa;Staffing Request" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane-sales">
          <mxGeometry x="100" y="45" width="140" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="req-analysis" value="Analyze&#xa;Requirements" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane-sales">
          <mxGeometry x="280" y="45" width="130" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="propose" value="Propose&#xa;Engineer Candidates" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane-sales">
          <mxGeometry x="450" y="45" width="150" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="negotiate" value="Contract&#xa;Negotiation" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane-sales">
          <mxGeometry x="780" y="45" width="130" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="e-s1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="start" target="client-need" parent="lane-sales"/>
        <mxCell id="e-s2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="client-need" target="req-analysis" parent="lane-sales"/>
        <mxCell id="e-s3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="req-analysis" target="propose" parent="lane-sales"/>
        <mxCell id="e-s5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="negotiate" target="contract-sign" parent="lane-sales"/>

        <mxCell id="contract-sign" value="Sign&#xa;Contract" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane-sales">
          <mxGeometry x="950" y="45" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- Swimlane: Client -->
        <mxCell id="lane-client" value="Client" style="shape=swimlane;startSize=30;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;horizontal=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="230" width="1260" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="interview" value="Technical&#xa;Interview" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane-client">
          <mxGeometry x="450" y="45" width="130" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="decision" value="Accept?" style="rhombus;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane-client">
          <mxGeometry x="630" y="35" width="80" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="reject" value="Reject /&#xa;Request Another" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane-client">
          <mxGeometry x="280" y="45" width="130" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="e-c1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="interview" target="decision" parent="lane-client"/>
        <mxCell id="e-c2" value="No" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontSize=11;strokeColor=#b85450;fontColor=#b85450;" edge="1" source="decision" target="reject" parent="lane-client"/>

        <!-- Swimlane: Engineer -->
        <mxCell id="lane-engineer" value="Engineer (SES Staff)" style="shape=swimlane;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;horizontal=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="390" width="1260" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="onboard" value="Onboarding /&#xa;Join Project" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane-engineer">
          <mxGeometry x="950" y="45" width="130" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="work" value="Perform Work&#xa;at Client Site" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane-engineer">
          <mxGeometry x="450" y="45" width="140" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="report" value="Submit Monthly&#xa;Timesheet" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane-engineer">
          <mxGeometry x="640" y="45" width="140" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="e-e1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="onboard" target="work" parent="lane-engineer"/>
        <mxCell id="e-e2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="work" target="report" parent="lane-engineer"/>

        <!-- Swimlane: Back Office -->
        <mxCell id="lane-backoffice" value="Back Office / Administration" style="shape=swimlane;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;horizontal=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="550" width="1260" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="billing" value="Issue&#xa;Invoice" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane-backoffice">
          <mxGeometry x="640" y="45" width="120" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="payment" value="Receive&#xa;Payment" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane-backoffice">
          <mxGeometry x="810" y="45" width="120" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="payroll" value="Pay Engineer&#xa;Salary" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane-backoffice">
          <mxGeometry x="980" y="45" width="120" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="renew-check" value="Contract&#xa;Renewal?" style="rhombus;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane-backoffice">
          <mxGeometry x="1100" y="35" width="80" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="e-b1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="billing" target="payment" parent="lane-backoffice"/>
        <mxCell id="e-b2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="payment" target="payroll" parent="lane-backoffice"/>
        <mxCell id="e-b3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="payroll" target="renew-check" parent="lane-backoffice"/>

        <!-- End -->
        <mxCell id="end" value="" style="ellipse;fillColor=#f8cecc;strokeColor=#b85450;aspect=fixed;" vertex="1" parent="1">
          <mxGeometry x="1230" y="730" width="40" height="40" as="geometry"/>
        </mxCell>

        <!-- Cross-lane edges -->
        <mxCell id="e-x1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="propose" target="interview" parent="1"/>
        <mxCell id="e-x2" value="Yes" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontSize=11;strokeColor=#82b366;fontColor=#82b366;" edge="1" source="decision" target="negotiate" parent="1"/>
        <mxCell id="e-x3" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#b85450;" edge="1" source="reject" target="propose" parent="1"/>
        <mxCell id="e-x4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="contract-sign" target="onboard" parent="1"/>
        <mxCell id="e-x5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="report" target="billing" parent="1"/>
        <mxCell id="e-x6" value="Yes" style="edgeStyle=orthogonalEdgeStyle;dashed=1;fontStyle=1;fontSize=11;strokeColor=#82b366;fontColor=#82b366;" edge="1" source="renew-check" target="work" parent="1"/>
        <mxCell id="e-x7" value="No" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontSize=11;strokeColor=#b85450;fontColor=#b85450;" edge="1" source="renew-check" target="end" parent="1"/>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
