<mxfile host="drawio-cmd">
  <diagram name="Billing Flow" id="billing-flow-1">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Corporate Billing Flow" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="300" height="40" as="geometry"/>
        </mxCell>

        <!-- Swimlane: Requester -->
        <mxCell id="lane-requester" value="Requester" style="shape=swimlane;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;horizontal=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="1020" height="140" as="geometry"/>
        </mxCell>

        <!-- Start -->
        <mxCell id="start" value="" style="ellipse;fillColor=#d5e8d4;strokeColor=#82b366;aspect=fixed;" vertex="1" parent="lane-requester">
          <mxGeometry x="30" y="50" width="40" height="40" as="geometry"/>
        </mxCell>

        <!-- Create Invoice -->
        <mxCell id="create-invoice" value="Create&#xa;Invoice Request" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane-requester">
          <mxGeometry x="120" y="40" width="130" height="60" as="geometry"/>
        </mxCell>

        <!-- Attach Evidence -->
        <mxCell id="attach-evidence" value="Attach&#xa;Evidence Documents" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane-requester">
          <mxGeometry x="300" y="40" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- Submit -->
        <mxCell id="submit" value="Submit&#xa;for Approval" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane-requester">
          <mxGeometry x="490" y="40" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- Edges in Requester lane -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="start" target="create-invoice" parent="lane-requester"/>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="create-invoice" target="attach-evidence" parent="lane-requester"/>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="attach-evidence" target="submit" parent="lane-requester"/>

        <!-- Swimlane: Manager -->
        <mxCell id="lane-manager" value="Manager" style="shape=swimlane;startSize=30;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;horizontal=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="230" width="1020" height="160" as="geometry"/>
        </mxCell>

        <!-- Review -->
        <mxCell id="review" value="Review&#xa;Invoice" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane-manager">
          <mxGeometry x="490" y="50" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- Decision -->
        <mxCell id="decision" value="Approved?" style="rhombus;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane-manager">
          <mxGeometry x="670" y="40" width="80" height="80" as="geometry"/>
        </mxCell>

        <!-- Reject -->
        <mxCell id="reject" value="Return&#xa;with Comments" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane-manager">
          <mxGeometry x="300" y="50" width="130" height="60" as="geometry"/>
        </mxCell>

        <!-- Edges in Manager lane -->
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="review" target="decision" parent="lane-manager"/>
        <mxCell id="e6" value="No" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontSize=11;" edge="1" source="decision" target="reject" parent="lane-manager"/>

        <!-- Swimlane: Finance -->
        <mxCell id="lane-finance" value="Finance Department" style="shape=swimlane;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;horizontal=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="400" width="1020" height="160" as="geometry"/>
        </mxCell>

        <!-- Process Payment -->
        <mxCell id="process-payment" value="Process&#xa;Payment" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane-finance">
          <mxGeometry x="670" y="50" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- Record -->
        <mxCell id="record" value="Record in&#xa;Accounting System" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane-finance">
          <mxGeometry x="840" y="50" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- End -->
        <mxCell id="end" value="" style="ellipse;fillColor=#f8cecc;strokeColor=#b85450;aspect=fixed;" vertex="1" parent="lane-finance">
          <mxGeometry x="940" y="130" width="40" height="40" as="geometry"/>
        </mxCell>

        <!-- Edges in Finance lane -->
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="process-payment" target="record" parent="lane-finance"/>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="record" target="end" parent="lane-finance"/>

        <!-- Cross-lane edges (parent=1) -->
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="submit" target="review" parent="1"/>
        <mxCell id="e7" value="Yes" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontSize=11;" edge="1" source="decision" target="process-payment" parent="1"/>
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;dashed=1;" edge="1" source="reject" target="create-invoice" parent="1"/>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
